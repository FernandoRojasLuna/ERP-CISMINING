<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <section class="module-print-report">
    <div class="module-print-banner">
      <div class="module-print-brand">
        <div class="module-print-logo" aria-hidden="true">
          <svg viewBox="0 0 64 64" role="img" focusable="false">
            <rect x="2" y="2" width="60" height="60" rx="14" fill="#0f172a"></rect>
            <path d="M18 44V20h8l6 8 6-8h8v24h-8V33l-6 8-6-8v11h-8z" fill="#f8fafc"></path>
            <rect x="12" y="48" width="40" height="5" rx="2.5" fill="#d4a017"></rect>
          </svg>
        </div>
        <div>
          <p class="module-print-company">Cismining</p>
          <p class="module-print-system">ERP Construcción</p>
        </div>
      </div>
      <div class="module-print-docmeta">
        <span>DOC-REPORTES</span>
        <strong>Version 1.0</strong>
      </div>
    </div>

    <div class="module-print-head">
      <div>
        <p class="module-print-eyebrow">Documento corporativo</p>
        <h2>Centro de Reportes - Resumen Ejecutivo</h2>
        <p>Consolidado de avances, costos y nómina para control gerencial.</p>
      </div>
      <div class="module-print-meta-right">
        <div><strong>Emitido:</strong> <%= emitido %></div>
        <div><strong>Periodo:</strong> <%= filtros?.desde || '-' %> a <%= filtros?.hasta || '-' %></div>
        <div><strong>Proyecto:</strong> <%= filtros?.proyecto_id ? ((proyectos || []).find((p) => String(p.id) === String(filtros.proyecto_id))?.nombre || 'Seleccionado') : 'Todos' %></div>
      </div>
    </div>

    <div class="module-print-metrics">
      <article><span>Avance global</span><strong><%= resumen?.avanceGlobal || 0 %>%</strong></article>
      <article><span>Actividades</span><strong><%= resumen?.totalActividades || 0 %></strong></article>
      <article><span>Costo ejecutado</span><strong>S/ <%= Number(resumen?.costoTotal || 0).toFixed(2) %></strong></article>
      <article><span>Nómina actual</span><strong>S/ <%= Number(resumen?.nominaActual || 0).toFixed(2) %></strong></article>
    </div>

    <p class="module-print-subtable-title">Comparativos Ejecutivos</p>
    <table class="table table-sm module-print-table">
      <thead>
        <tr>
          <th>Indicador</th>
          <th>Vs mes anterior</th>
          <th>Vs año anterior</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Costo ejecutado</td>
          <td><strong><%= Number(resumen?.variacionCostoMoMPct || 0).toFixed(2) %>%</strong></td>
          <td><strong><%= Number(resumen?.variacionCostoYoYPct || 0).toFixed(2) %>%</strong></td>
        </tr>
        <tr>
          <td>Nómina</td>
          <td><strong><%= Number(resumen?.variacionNominaPct || 0).toFixed(2) %>%</strong></td>
          <td><strong><%= Number(resumen?.variacionNominaYoYPct || 0).toFixed(2) %>%</strong></td>
        </tr>
      </tbody>
    </table>

    <p class="module-print-subtable-title">Avance por Proyecto</p>
    <table class="table table-sm module-print-table">
      <thead>
        <tr>
          <th>Proyecto</th>
          <th>Actividades</th>
          <th>Avance %</th>
        </tr>
      </thead>
      <tbody>
        <% if (!Array.isArray(avancePorProyecto) || !avancePorProyecto.length) { %>
          <tr><td colspan="3" class="text-center">Sin datos de avance para el periodo.</td></tr>
        <% } %>
        <% (avancePorProyecto || []).forEach((row) => { %>
          <tr>
            <td><%= row.nombre %></td>
            <td><%= row.actividades %></td>
            <td><strong><%= Number(row.avance_promedio || 0).toFixed(2) %>%</strong></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <p class="module-print-subtable-title">Costos por Categoria</p>
    <table class="table table-sm module-print-table">
      <thead>
        <tr>
          <th>Categoria</th>
          <th>Monto (S/)</th>
          <th>Participacion</th>
        </tr>
      </thead>
      <tbody>
        <% if (!Array.isArray(costosPorCategoria) || !costosPorCategoria.length) { %>
          <tr><td colspan="3" class="text-center">Sin costos registrados para el periodo.</td></tr>
        <% } %>
        <% (costosPorCategoria || []).forEach((row) => { %>
          <tr>
            <td><%= row.categoria %></td>
            <td><strong><%= Number(row.total || 0).toFixed(2) %></strong></td>
            <td><%= totalCostos ? ((Number(row.total || 0) / totalCostos) * 100).toFixed(1) : '0.0' %>%</td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <p class="module-print-subtable-title">Nómina por Periodo</p>
    <table class="table table-sm module-print-table">
      <thead>
        <tr>
          <th>Periodo</th>
          <th>Total nómina (S/)</th>
        </tr>
      </thead>
      <tbody>
        <% if (!Array.isArray(nominaResumen) || !nominaResumen.length) { %>
          <tr><td colspan="2" class="text-center">Sin datos de nómina para el periodo.</td></tr>
        <% } %>
        <% (nominaResumen || []).forEach((row) => { %>
          <tr>
            <td><%= row.periodo %></td>
            <td><strong><%= Number(row.total_nomina || 0).toFixed(2) %></strong></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="module-print-footer">
      <div>
        <span class="label">Documento:</span>
        <strong>Centro de Reportes</strong>
      </div>
      <div>
        <span class="label">Clasificacion:</span>
        <strong>Uso Interno - Gerencia</strong>
      </div>
    </div>
  </section>

  <script>
    window.addEventListener('load', () => {
      window.print();
    });
  </script>
</body>
</html>
