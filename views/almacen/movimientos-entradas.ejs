<script>
  function exportarProyectoPDF() {
    document.body.classList.add('print-project-almacen');
    window.print();
    setTimeout(function() {
      document.body.classList.remove('print-project-almacen');
    }, 250);
  }

  (function initEntradaForm() {
    const materialSelect = document.getElementById('materialSelectEntrada');
    const unidadInput = document.getElementById('unidadEntrada');

    if (!materialSelect) return;

    function syncUnidad() {
      const selectedOption = materialSelect.options[materialSelect.selectedIndex];
      if (selectedOption && selectedOption.value) {
        unidadInput.value = selectedOption.getAttribute('data-unidad') || '-';
      } else {
        unidadInput.value = '-';
      }
    }

    materialSelect.addEventListener('change', syncUnidad);
    syncUnidad();

    // AUTOCOMPLETE para MATERIAL
    const materialSearchInput = document.getElementById('materialSelectEntrada');
    const materialSuggestionsDiv = document.createElement('div');
    materialSuggestionsDiv.id = 'materialSuggestionsEntradaDiv';
    materialSuggestionsDiv.style.cssText = 'position: absolute; background: white; border: 1px solid #d1d5db; border-top: none; border-radius: 0 0 8px 8px; max-height: 200px; overflow-y: auto; width: auto; z-index: 1000; display: none;';
    
    const originalMaterialOptions = Array.from(materialSelect.options).slice(1).map(opt => ({
      value: opt.value,
      text: opt.textContent,
      element: opt
    }));

    function filterAndShowMaterialSuggestions(searchTerm) {
      const filtered = originalMaterialOptions.filter(opt => 
        opt.text.toUpperCase().includes(searchTerm.toUpperCase())
      );

      materialSuggestionsDiv.innerHTML = '';
      if (filtered.length > 0 && searchTerm.length > 0) {
        filtered.forEach(opt => {
          const div = document.createElement('div');
          div.textContent = opt.text;
          div.style.cssText = 'padding: 8px 12px; cursor: pointer; border-bottom: 1px solid #f3f4f6; background: white;';
          div.onmouseover = () => div.style.background = '#f9fafb';
          div.onmouseout = () => div.style.background = 'white';
          div.onclick = () => {
            materialSelect.value = opt.value;
            syncUnidad();
            materialSuggestionsDiv.style.display = 'none';
          };
          materialSuggestionsDiv.appendChild(div);
        });
        materialSuggestionsDiv.style.display = 'block';
      } else {
        materialSuggestionsDiv.style.display = 'none';
      }
    }

    // Reemplazar select con input de búsqueda para material
    const materialInputSearch = document.createElement('input');
    materialInputSearch.type = 'text';
    materialInputSearch.id = 'materialSearchInput';
    materialInputSearch.placeholder = 'Escribe para buscar material...';
    materialInputSearch.className = 'form-control';
    materialInputSearch.style.marginBottom = '8px';
    materialSelect.parentNode.insertBefore(materialInputSearch, materialSelect);
    
    materialInputSearch.addEventListener('input', (e) => filterAndShowMaterialSuggestions(e.target.value));
    materialInputSearch.addEventListener('focus', (e) => filterAndShowMaterialSuggestions(e.target.value));
    materialInputSearch.parentNode.appendChild(materialSuggestionsDiv);

  })();

  function abrirModalProveedorEntrada() {
    const modal = new bootstrap.Modal(document.getElementById('modalProveedorEntrada'));
    modal.show();
  }

  function mostrarToastProveedorEntrada(mensaje, tipo) {
    const toastType = tipo === 'error' ? 'danger' : (tipo === 'warning' ? 'warning' : 'success');
    let container = document.getElementById('toastProveedorEntradaContainer');

    if (!container) {
      container = document.createElement('div');
      container.id = 'toastProveedorEntradaContainer';
      container.className = 'toast-container position-fixed top-0 end-0 p-3';
      container.style.zIndex = '2000';
      document.body.appendChild(container);
    }

    const toastEl = document.createElement('div');
    toastEl.className = 'toast align-items-center text-bg-' + toastType + ' border-0';
    toastEl.setAttribute('role', 'alert');
    toastEl.setAttribute('aria-live', 'assertive');
    toastEl.setAttribute('aria-atomic', 'true');

    toastEl.innerHTML = '<div class="d-flex">'
      + '<div class="toast-body">' + String(mensaje || '') + '</div>'
      + '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Cerrar"></button>'
      + '</div>';

    container.appendChild(toastEl);
    const toast = new bootstrap.Toast(toastEl, { delay: 3200 });
    toast.show();
    toastEl.addEventListener('hidden.bs.toast', function() {
      toastEl.remove();
    });
  }

  function initFormProveedorEntrada() {
    const formProveedorEntrada = document.getElementById('formProveedorEntrada');
    if (!formProveedorEntrada) {
      return;
    }

    formProveedorEntrada.addEventListener('submit', async function(e) {
      e.preventDefault();
      const formData = new FormData(this);

      try {
        const response = await fetch('/almacen/proveedores', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({
            nombre: formData.get('nombre'),
            ruc: formData.get('ruc'),
            contacto: formData.get('contacto'),
            telefono: formData.get('telefono'),
            email: formData.get('email'),
            direccion: formData.get('direccion')
          })
        });

        const data = await response.json();

        if (response.ok && data.success) {
          // Agregar el proveedor al select oculto para poder seleccionarlo inmediatamente.
          const select = document.getElementById('proveedorSelectEntrada');
          const option = document.createElement('option');
          option.value = data.id;
          option.setAttribute('data-nombre', data.nombre);
          option.setAttribute('data-ruc', data.ruc);
          option.textContent = data.nombre + ' · ' + data.ruc;
          select.appendChild(option);

          const searchInput = document.getElementById('proveedorSearchEntrada');
          if (searchInput) {
            searchInput.value = data.nombre;
            select.value = data.id;
          }

          this.reset();

          const modalEl = document.getElementById('modalProveedorEntrada');
          const modal = bootstrap.Modal.getInstance(modalEl);
          if (modal) {
            modal.hide();
          }

          mostrarToastProveedorEntrada('Proveedor creado exitosamente.', 'success');
        } else {
          mostrarToastProveedorEntrada('Error al crear el proveedor: ' + (data.error || 'Error desconocido'), 'error');
        }
      } catch (error) {
        console.error('Error:', error);
        mostrarToastProveedorEntrada('Error al crear el proveedor: ' + error.message, 'error');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFormProveedorEntrada);
  } else {
    initFormProveedorEntrada();
  }

  // AUTOCOMPLETE para PROVEEDOR
  (function initProveedorAutocomplete() {
    const proveedorSearchInput = document.getElementById('proveedorSearchEntrada');
    const proveedorSelectHidden = document.getElementById('proveedorSelectEntrada');
    const proveedorSuggestionsDiv = document.getElementById('proveedorSuggestionsEntrada');
    
    if (!proveedorSearchInput || !proveedorSelectHidden) return;

    function getAllProveedores() {
      return Array.from(proveedorSelectHidden.options)
        .slice(1)
        .map(opt => ({
          id: opt.value,
          nombre: opt.getAttribute('data-nombre') || opt.textContent.split(' · ')[0],
          ruc: opt.getAttribute('data-ruc') || opt.textContent.split(' · ')[1] || '',
          text: opt.textContent
        }));
    }

    function filterAndShowProveedorSuggestions(searchTerm) {
      const allProveedores = getAllProveedores();
      const filtered = allProveedores.filter(prov => 
        prov.nombre.toUpperCase().includes(searchTerm.toUpperCase()) ||
        prov.ruc.toUpperCase().includes(searchTerm.toUpperCase())
      );

      proveedorSuggestionsDiv.innerHTML = '';
      if (filtered.length > 0 && searchTerm.length > 0) {
        filtered.slice(0, 10).forEach(prov => {
          const div = document.createElement('div');
          div.textContent = prov.nombre + ' · ' + (prov.ruc || 'sin RUC');
          div.style.cssText = 'padding: 8px 12px; cursor: pointer; border-bottom: 1px solid #f3f4f6; background: white;';
          div.onmouseover = () => div.style.background = '#f9fafb';
          div.onmouseout = () => div.style.background = 'white';
          div.onclick = () => {
            proveedorSelectHidden.value = prov.id;
            proveedorSearchInput.value = prov.nombre;
            proveedorSuggestionsDiv.style.display = 'none';
          };
          proveedorSuggestionsDiv.appendChild(div);
        });
        proveedorSuggestionsDiv.style.display = 'block';
      } else {
        proveedorSuggestionsDiv.style.display = 'none';
      }
    }

    proveedorSearchInput.addEventListener('input', (e) => {
      if (!e.target.value.trim()) {
        proveedorSelectHidden.value = '';
      }
      filterAndShowProveedorSuggestions(e.target.value);
    });
    proveedorSearchInput.addEventListener('focus', (e) => filterAndShowProveedorSuggestions(e.target.value));
    proveedorSearchInput.addEventListener('blur', () => {
      setTimeout(() => {
        proveedorSuggestionsDiv.style.display = 'none';
      }, 150);
    });
  })();
</script>

