<%
  const currentUser = typeof locals.currentUser === 'object' ? locals.currentUser : {};
  const selectedProyecto = typeof locals.selectedProyecto === 'object' ? locals.selectedProyecto : {};
  const asignaciones = Array.isArray(locals.asignaciones) ? locals.asignaciones : [];
  const proveedores = Array.isArray(locals.proveedores) ? locals.proveedores : [];
  const entradas = Array.isArray(locals.entradas) ? locals.entradas : [];
  const totalEntradas = Number(locals.totalEntradas || entradas.length || 0);

  const fmtFecha = (date) => {
    const d = new Date(date);
    if (Number.isNaN(d.getTime())) return '-';
    return d.toLocaleDateString('es-PE', { day: '2-digit', month: '2-digit', year: 'numeric' });
  };

  const up = (value, fallback = '-') => {
    const cleaned = String(value || '').trim();
    return cleaned ? cleaned.toUpperCase() : fallback;
  };
%>

<div class="page-header">
  <div class="page-header-title">
    <h1>Almacen por Proyecto</h1>
    <p>Gestion detallada de materiales asignados para la obra seleccionada</p>
  </div>
  <div class="d-flex align-items-center gap-2 no-print">
    <a href="/almacen/movimientos" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left"></i> Volver a movimientos
    </a>
    <button type="button" class="btn btn-export-pdf" onclick="exportarProyectoPDF()">
      <i class="bi bi-file-earmark-pdf"></i> Exportar Proyecto a PDF
    </button>
  </div>
</div>

<section class="module-print-report print-only project-print-report" aria-hidden="true">
  <div class="module-print-banner">
    <div class="module-print-brand">
      <div class="module-print-logo" aria-hidden="true">
        <svg viewBox="0 0 64 64" role="img" focusable="false">
          <rect x="2" y="2" width="60" height="60" rx="14" fill="#0f172a"></rect>
          <path d="M18 44V20h8l6 8 6-8h8v24h-8V33l-6 8-6-8v11h-8z" fill="#f8fafc"></path>
          <rect x="12" y="48" width="40" height="5" rx="2.5" fill="#d4a017"></rect>
        </svg>
      </div>
      <div>
        <p class="module-print-company">Cismining</p>
        <p class="module-print-system">ERP Construccion</p>
      </div>
    </div>
    <div class="module-print-docmeta">
      <span>DOC-MOV-PROY</span>
      <strong>Version 1.0</strong>
    </div>
  </div>

  <div class="module-print-head">
    <div>
      <p class="module-print-eyebrow">Documento corporativo</p>
      <h2>Reporte de Entradas por Proyecto</h2>
      <p>Detalle de ingresos de materiales para el proyecto seleccionado.</p>
    </div>
    <div class="module-print-meta-right">
      <div><strong>Proyecto:</strong> <%= up(selectedProyecto.nombre || '-') %></div>
      <div><strong>Emitido:</strong> <%= fmtFecha(new Date()) %></div>
      <div><strong>Preparado por:</strong> <%= up(currentUser?.nombre || 'SISTEMA') %></div>
    </div>
  </div>

  <div class="module-print-metrics">
    <article><span>Entradas</span><strong><%= totalEntradas %></strong></article>
    <article><span>Proveedores</span><strong><%= proveedores.length %></strong></article>
    <article><span>Asignaciones</span><strong><%= asignaciones.length %></strong></article>
  </div>

  <table class="table table-sm module-print-table">
    <thead>
      <tr>
        <th>Fecha</th>
        <th>Documento</th>
        <th>Proveedor</th>
        <th>Material</th>
        <th>Cantidad</th>
        <th>Nuevo Saldo</th>
        <th>Observacion</th>
      </tr>
    </thead>
    <tbody>
      <% entradas.forEach((e) => { %>
        <tr>
          <td><%= fmtFecha(e.fecha) %></td>
          <td><%= up(e.referencia_documento || '-') %></td>
          <td><%= up(e.proveedor_nombre || '-') %></td>
          <td><%= up(e.material || '-') %> · <%= up(e.unidad || '-') %></td>
          <td><%= Number(e.cantidad || 0).toFixed(2) %></td>
          <td><%= Number(e.saldo_resultante || 0).toFixed(2) %></td>
          <td><%= up(e.observacion || '-') %></td>
        </tr>
      <% }) %>
      <% if (!entradas.length) { %>
        <tr><td colspan="7" class="text-center">Sin entradas registradas para este proyecto.</td></tr>
      <% } %>
    </tbody>
  </table>
</section>

<div class="submodule-shell no-print">
  <nav class="submodule-tabs" aria-label="Submodulos de almacen">
    <a href="/almacen?mod=base-materiales" class="submodule-tab">
      <i class="bi bi-database"></i>
      <span>Base de Datos Materiales</span>
    </a>
    <a href="/almacen?mod=almacen" class="submodule-tab">
      <i class="bi bi-boxes"></i>
      <span>Almacen por Proyecto</span>
    </a>
    <a href="/almacen/movimientos" class="submodule-tab active">
      <i class="bi bi-arrow-left-right"></i>
      <span>Movimientos</span>
    </a>
  </nav>

  <div class="row g-3 submodule-kpis">
    <div class="col-md-3 col-sm-6">
      <div class="kpi-mini">
        <div class="kpi-mini-left"><i class="bi bi-building"></i><span class="kpi-mini-label">Proyecto</span></div>
        <span class="kpi-mini-value"><%= up(selectedProyecto.nombre || '-') %></span>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="kpi-mini">
        <div class="kpi-mini-left"><i class="bi bi-geo-alt"></i><span class="kpi-mini-label">Ubicacion</span></div>
        <span class="kpi-mini-value" style="font-size: 14px;"><%= up(selectedProyecto.ubicacion || '-') %></span>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="kpi-mini">
        <div class="kpi-mini-left"><i class="bi bi-box2"></i><span class="kpi-mini-label">Asignaciones</span></div>
        <span class="kpi-mini-value"><%= asignaciones.length %></span>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="kpi-mini">
        <div class="kpi-mini-left"><i class="bi bi-clock-history"></i><span class="kpi-mini-label">Entradas</span></div>
        <span class="kpi-mini-value"><%= entradas.length %></span>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-5">
      <div class="form-section">
        <div class="form-section-title">
          <i class="bi bi-arrow-down-circle" style="color: #10b981;"></i> Nueva Nota de Entrada
        </div>
        <div class="form-section-body">
          <form action="/almacen/movimientos/<%= selectedProyecto.id %>/entradas" method="post" class="row g-3" id="formEntrada">
            <div class="col-12">
              <label class="form-label">Documento de Referencia <span class="badge badge-required">Obligatorio</span></label>
              <input type="text" name="documento_referencia" class="form-control" placeholder="Nro Guia, Factura, OC (ej: OC-1002, GUIA-456)" required maxlength="80">
              <small class="field-hint">Numero unico de documento externo para trazabilidad</small>
            </div>

            <div class="col-12">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 8px;">
                <label class="form-label" style="margin-bottom: 0;">Proveedor <span class="badge badge-required">Obligatorio</span></label>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="abrirModalProveedorEntrada()" title="Crear nuevo proveedor" style="padding: 4px 8px; height: auto; margin-left: auto;">
                  <i class="bi bi-pencil-square" style="font-size: 14px;"></i>
                </button>
              </div>
              <input type="text" id="proveedorSearchEntrada" class="form-control" placeholder="Escribe para buscar proveedor..." autocomplete="off">
              <div id="proveedorSuggestionsEntrada" style="position: absolute; background: white; border: 1px solid #d1d5db; border-top: none; border-radius: 0 0 8px 8px; max-height: 200px; overflow-y: auto; width: 100%; z-index: 1000; display: none; margin-top: -4px;"></div>
              <select name="proveedor_id" class="form-select" id="proveedorSelectEntrada" required style="display: none;">
                <option value="">Selecciona proveedor</option>
                <% proveedores.forEach((p) => { %>
                  <option value="<%= p.id %>" data-nombre="<%= up(p.nombre) %>" data-ruc="<%= p.ruc || '' %>"><%= up(p.nombre) %> · <%= p.ruc || 'sin RUC' %></option>
                <% }) %>
              </select>
              <small class="field-hint">De quien se compro el material</small>
            </div>

            <div class="col-12">
              <label class="form-label">Material <span class="badge badge-required">Obligatorio</span></label>
              <select name="almacen_material_id" class="form-select" id="materialSelectEntrada" required>
                <option value="">Selecciona material del proyecto</option>
                <% asignaciones.forEach((a) => { %>
                  <option
                    value="<%= a.id %>"
                    data-material-id="<%= a.material_id %>"
                    data-material="<%= up(a.material_nombre) %>"
                    data-unidad="<%= up(a.unidad || '-') %>"
                    data-saldo="<%= Number(a.cantidad_disponible || 0) %>">
                    <%= up(a.material_nombre) %> · <%= up(a.unidad || '-') %> · SALDO ACTUAL: <%= Number(a.cantidad_disponible || 0).toFixed(2) %>
                  </option>
                <% }) %>
              </select>
              <small class="field-hint">Solo muestra materiales asignados a este proyecto</small>
            </div>

            <div class="col-md-6">
              <label class="form-label">Cantidad de Ingreso <span class="badge badge-required">Obligatorio</span></label>
              <input type="number" name="cantidad" class="form-control" id="cantidadEntrada" placeholder="0" step="0.01" min="0.01" required>
            </div>

            <div class="col-md-6">
              <label class="form-label">Unidad</label>
              <input type="text" class="form-control" id="unidadEntrada" readonly placeholder="-">
            </div>

            <div class="col-12">
              <label class="form-label">Observacion</label>
              <textarea name="observacion" class="form-control" placeholder="Detalles adicionales (opcional)" rows="2" maxlength="255"></textarea>
            </div>

            <div class="col-12 pt-1">
              <button class="btn btn-ingreso" id="btnRegistrarEntrada" style="width: 100%; background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none; color: white; padding: 10px 20px; border-radius: 8px; font-weight: 600;">
                <i class="bi bi-check2-circle"></i> Registrar Entrada
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-7">
      <div class="panel-card">
        <div class="panel-card-header">
          <div class="panel-title"><i class="bi bi-history"></i> Historial de Entradas</div>
          <span class="badge badge-secondary"><%= entradas.length %> registros</span>
        </div>
        <div class="table-responsive">
          <table class="table align-middle table-hover">
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Documento</th>
                <th>Proveedor</th>
                <th>Material</th>
                <th>Cantidad</th>
                <th>Nuevo Saldo</th>
                <th>Observacion</th>
              </tr>
            </thead>
            <tbody>
              <% entradas.forEach((e) => { %>
                <tr>
                  <td><small class="text-muted"><%= fmtFecha(e.fecha) %></small></td>
                  <td>
                    <span class="badge" style="background: #dcfce7; color: #166534; border: 1px solid #a7f3d0; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 500;"><%= up(e.referencia_documento || '-') %></span>
                  </td>
                  <td>
                    <strong style="color: #059669;"><%= up(e.proveedor_nombre || '-') %></strong>
                  </td>
                  <td>
                    <div class="fw-semibold"><%= up(e.material || '-') %></div>
                    <small class="text-muted"><%= up(e.unidad || '-') %></small>
                  </td>
                  <td class="fw-semibold" style="color: #059669;">
                    <i class="bi bi-arrow-down"></i> <%= Number(e.cantidad || 0).toFixed(2) %>
                  </td>
                  <td class="fw-semibold">
                    <%= Number(e.saldo_resultante || 0).toFixed(2) %> <%= up(e.unidad || '') %>
                  </td>
                  <td><small class="text-muted"><%= up(e.observacion || '-') %></small></td>
                </tr>
              <% }) %>
              <% if (!entradas.length) { %>
                <tr>
                  <td colspan="7">
                    <div class="empty-state">
                      <i class="bi bi-inbox"></i>
                      <p>Sin entradas registradas aun</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

