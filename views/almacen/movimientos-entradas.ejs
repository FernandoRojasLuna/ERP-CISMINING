          <input type="email" name="email" class="form-control" placeholder="correo@proveedor.com" maxlength="100">
        </div>

        <div class="col-12 pt-2">
          <div style="display: flex; gap: 8px;">
            <button type="submit" class="btn btn-primary" style="flex: 1;">
              <i class="bi bi-check-lg"></i> Guardar Proveedor
            </button>
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="flex: 1;">
              Cancelar
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>
