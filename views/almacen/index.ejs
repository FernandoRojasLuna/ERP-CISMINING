            </div>
          
            <div class="mb-3">
              <label class="form-label" style="font-weight: 600; color: #374151;">Contacto</label>
              <input type="text" class="form-control" id="editProveedorContacto" placeholder="Nombre contacto">
            </div>
          
            <div class="mb-3">
              <label class="form-label" style="font-weight: 600; color: #374151;">Teléfono</label>
