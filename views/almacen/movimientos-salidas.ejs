    padding: 40px 20px;
    color: #6b7280;
  }

  .empty-state i {
    font-size: 48px;
    margin-bottom: 12px;
    opacity: 0.3;
    display: block;
  }

  .empty-state p {
    margin: 0;
    font-size: 14px;
  }

  .text-danger {
    color: #dc2626;
  }

  .text-muted {
    color: #6b7280;
  }

  .fw-semibold {
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .row.g-3 > .col-lg-5,
    .row.g-3 > .col-lg-7 {
      grid-column: 1 / -1;
    }

    .table-responsive {
      margin-left: -15px;
      margin-right: -15px;
    }

    .table {
      font-size: 12px;
    }
  }
</style>

<script>
  function exportarProyectoPDF() {
    document.body.classList.add('print-project-almacen');
    window.print();
    setTimeout(function() {
      document.body.classList.remove('print-project-almacen');
    }, 250);
  }

  (function initSalidaForm() {
    const materialSelectHidden = document.getElementById('materialSelectSalida');
    const materialSearchInput = document.getElementById('materialSearchInputSalida');
    const materialSuggestionsDiv = document.getElementById('materialSuggestionsSalidaDiv');
    const cantidadInput = document.getElementById('cantidadSalida');
    const unidadInput = document.getElementById('unidadSalida');
    const btnRegistrar = document.getElementById('btnRegistrarSalida');
    const stockMsg = document.getElementById('stockValidationMsg');

    if (!materialSelectHidden || !materialSearchInput) return;

    const allMateriales = Array.from(materialSelectHidden.options)
      .slice(1)
      .map(opt => ({
        id: opt.value,
        nombre: opt.getAttribute('data-material') || opt.textContent.split(' · ')[0],
        unidad: opt.getAttribute('data-unidad'),
        saldo: Number(opt.getAttribute('data-saldo') || 0),
        text: opt.textContent
      }));

    function filterAndShowMaterialSuggestions(searchTerm) {
      const filtered = allMateriales.filter(mat => 
        mat.nombre.toUpperCase().includes(searchTerm.toUpperCase()) ||
        mat.text.toUpperCase().includes(searchTerm.toUpperCase())
      );

      materialSuggestionsDiv.innerHTML = '';
      if (filtered.length > 0 && searchTerm.length > 0) {
        filtered.slice(0, 10).forEach(mat => {
          const div = document.createElement('div');
          div.textContent = mat.nombre + ' · ' + mat.unidad + ' · DISPONIBLE: ' + mat.saldo.toFixed(2);
          div.style.cssText = 'padding: 8px 12px; cursor: pointer; border-bottom: 1px solid #f3f4f6; background: white;';
          div.onmouseover = () => div.style.background = '#f9fafb';
          div.onmouseout = () => div.style.background = 'white';
          div.onclick = () => {
            materialSelectHidden.value = mat.id;
            materialSearchInput.value = mat.nombre;
            materialSuggestionsDiv.style.display = 'none';
            syncUnidad();
          };
          materialSuggestionsDiv.appendChild(div);
        });
        materialSuggestionsDiv.style.display = 'block';
      } else {
        materialSuggestionsDiv.style.display = 'none';
      }
    }

    function syncUnidad() {
      const selectedOption = materialSelectHidden.options[materialSelectHidden.selectedIndex];
      if (selectedOption && selectedOption.value) {
        unidadInput.value = selectedOption.getAttribute('data-unidad') || '-';
      } else {
        unidadInput.value = '-';
      }
      validateStockSalida();
    }

    function getSaldoDisponible() {
      const selectedOption = materialSelectHidden.options[materialSelectHidden.selectedIndex];
      if (selectedOption && selectedOption.value) {
        return Number(selectedOption.getAttribute('data-saldo') || 0);
      }
      return 0;
    }

    function validateStockSalida() {
      const cantidad = Number(cantidadInput.value || 0);
      const saldo = getSaldoDisponible();
      const selectedOption = materialSelectHidden.options[materialSelectHidden.selectedIndex];

      stockMsg.classList.remove('show', 'warning', 'error', 'success');
      btnRegistrar.classList.remove('btn-danger');

      if (!selectedOption || !selectedOption.value) {
        stockMsg.innerHTML = '';
        return;
      }

      if (cantidad <= 0) {
        return;
      }

      if (cantidad > saldo) {
        stockMsg.innerHTML = `<i class="bi bi-exclamation-triangle-fill"></i> STOCK INSUFICIENTE: tienes ${saldo.toFixed(2)} disponibles, necesitas ${cantidad.toFixed(2)}`;
        stockMsg.classList.add('show', 'error');
        btnRegistrar.disabled = true;
        btnRegistrar.classList.add('btn-danger');
      } else if (cantidad === saldo) {
        stockMsg.innerHTML = `<i class="bi bi-info-circle"></i> Nota: utilizaras TODO el stock disponible (${saldo.toFixed(2)})`;
        stockMsg.classList.add('show', 'warning');
        btnRegistrar.disabled = false;
        btnRegistrar.classList.remove('btn-danger');
      } else {
        stockMsg.innerHTML = `<i class="bi bi-check-circle-fill"></i> Stock valido. Quedaran ${(saldo - cantidad).toFixed(2)} disponibles`;
        stockMsg.classList.add('show', 'success');
        btnRegistrar.disabled = false;
        btnRegistrar.classList.remove('btn-danger');
      }
    }

    materialSearchInput.addEventListener('input', (e) => filterAndShowMaterialSuggestions(e.target.value));
    materialSearchInput.addEventListener('focus', (e) => filterAndShowMaterialSuggestions(e.target.value));
    materialSearchInput.addEventListener('blur', () => {
      setTimeout(() => {
        materialSuggestionsDiv.style.display = 'none';
      }, 150);
    });
    cantidadInput.addEventListener('input', validateStockSalida);
    syncUnidad();
  })();
</script>
