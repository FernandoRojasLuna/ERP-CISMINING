<%
  const currentUser = typeof locals.currentUser === 'object' ? locals.currentUser : {};
  const selectedProyecto = typeof locals.selectedProyecto === 'object' ? locals.selectedProyecto : {};
  const asignaciones = Array.isArray(locals.asignaciones) ? locals.asignaciones : [];
  const salidas = Array.isArray(locals.salidas) ? locals.salidas : [];
  const totalSalidas = Number(locals.totalSalidas || salidas.length || 0);

  const fmtFecha = (date) => {
    const d = new Date(date);
    if (Number.isNaN(d.getTime())) return '-';
    return d.toLocaleDateString('es-PE', { day: '2-digit', month: '2-digit', year: 'numeric' });
  };

  const up = (value, fallback = '-') => {
    const cleaned = String(value || '').trim();
    return cleaned ? cleaned.toUpperCase() : fallback;
  };
%>

<div class="page-header">
  <div class="page-header-title">
    <h1>Almacen por Proyecto</h1>
    <p>Gestion detallada de materiales asignados para la obra seleccionada</p>
  </div>
  <div class="d-flex align-items-center gap-2 no-print">
    <a href="/almacen/movimientos" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left"></i> Volver a movimientos
    </a>
    <button type="button" class="btn btn-export-pdf" onclick="exportarProyectoPDF()">
      <i class="bi bi-file-earmark-pdf"></i> Exportar Proyecto a PDF
    </button>
  </div>
</div>

<section class="module-print-report print-only project-print-report" aria-hidden="true">
  <div class="module-print-banner">
    <div class="module-print-brand">
      <div class="module-print-logo" aria-hidden="true">
        <svg viewBox="0 0 64 64" role="img" focusable="false">
          <rect x="2" y="2" width="60" height="60" rx="14" fill="#0f172a"></rect>
          <path d="M18 44V20h8l6 8 6-8h8v24h-8V33l-6 8-6-8v11h-8z" fill="#f8fafc"></path>
          <rect x="12" y="48" width="40" height="5" rx="2.5" fill="#d4a017"></rect>
        </svg>
      </div>
      <div>
        <p class="module-print-company">Cismining</p>
        <p class="module-print-system">ERP Construccion</p>
      </div>
    </div>
    <div class="module-print-docmeta">
      <span>DOC-MOV-PROY</span>
      <strong>Version 1.0</strong>
    </div>
  </div>

  <div class="module-print-head">
    <div>
      <p class="module-print-eyebrow">Documento corporativo</p>
      <h2>Reporte de Salidas por Proyecto</h2>
      <p>Detalle de retiros y consumo de materiales del proyecto seleccionado.</p>
    </div>
    <div class="module-print-meta-right">
      <div><strong>Proyecto:</strong> <%= up(selectedProyecto.nombre || '-') %></div>
      <div><strong>Emitido:</strong> <%= fmtFecha(new Date()) %></div>
      <div><strong>Preparado por:</strong> <%= up(currentUser?.nombre || 'SISTEMA') %></div>
    </div>
  </div>

  <div class="module-print-metrics">
    <article><span>Salidas</span><strong><%= totalSalidas %></strong></article>
    <article><span>Asignaciones</span><strong><%= asignaciones.length %></strong></article>
  </div>

  <table class="table table-sm module-print-table">
    <thead>
      <tr>
        <th>Fecha</th>
        <th>Frente / Partida</th>
        <th>Responsable</th>
        <th>Material</th>
        <th>Cantidad</th>
        <th>Nuevo Saldo</th>
        <th>Observacion</th>
      </tr>
    </thead>
    <tbody>
      <% salidas.forEach((s) => { %>
        <tr>
          <td><%= fmtFecha(s.fecha) %></td>
          <td><%= up(s.destino_frente || '-') %></td>
          <td><%= up(s.responsable_movimiento || '-') %></td>
          <td><%= up(s.material || '-') %> · <%= up(s.unidad || '-') %></td>
          <td><%= Number(s.cantidad || 0).toFixed(2) %></td>
          <td><%= Number(s.saldo_resultante || 0).toFixed(2) %></td>
          <td><%= up(s.observacion || '-') %></td>
        </tr>
      <% }) %>
      <% if (!salidas.length) { %>
        <tr><td colspan="7" class="text-center">Sin salidas registradas para este proyecto.</td></tr>
      <% } %>
    </tbody>
  </table>
</section>

<div class="submodule-shell no-print">
  <nav class="submodule-tabs" aria-label="Submodulos de almacen">
    <a href="/almacen?mod=base-materiales" class="submodule-tab">
      <i class="bi bi-database"></i>
      <span>Base de Datos Materiales</span>
    </a>
    <a href="/almacen?mod=almacen" class="submodule-tab">
      <i class="bi bi-boxes"></i>
      <span>Almacen por Proyecto</span>
    </a>
    <a href="/almacen/movimientos" class="submodule-tab active">
      <i class="bi bi-arrow-left-right"></i>
      <span>Movimientos</span>
    </a>
  </nav>

  <div class="row g-3 submodule-kpis">
    <div class="col-md-3 col-sm-6">
      <div class="kpi-mini">
        <div class="kpi-mini-left"><i class="bi bi-building"></i><span class="kpi-mini-label">Proyecto</span></div>
        <span class="kpi-mini-value"><%= up(selectedProyecto.nombre || '-') %></span>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="kpi-mini">
        <div class="kpi-mini-left"><i class="bi bi-geo-alt"></i><span class="kpi-mini-label">Ubicacion</span></div>
        <span class="kpi-mini-value" style="font-size: 14px;"><%= up(selectedProyecto.ubicacion || '-') %></span>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="kpi-mini">
        <div class="kpi-mini-left"><i class="bi bi-box2"></i><span class="kpi-mini-label">Asignaciones</span></div>
        <span class="kpi-mini-value"><%= asignaciones.length %></span>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="kpi-mini">
        <div class="kpi-mini-left"><i class="bi bi-clock-history"></i><span class="kpi-mini-label">Salidas</span></div>
        <span class="kpi-mini-value"><%= salidas.length %></span>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-5">
      <div class="form-section">
        <div class="form-section-title">
          <i class="bi bi-arrow-up-circle" style="color: #ef4444;"></i> Nueva Nota de Salida
        </div>
        <div class="form-section-body">
          <form action="/almacen/movimientos/<%= selectedProyecto.id %>/salidas" method="post" class="row g-3" id="formSalida">
            <div class="col-12">
              <label class="form-label">Frente / Partida de Trabajo <span class="badge badge-required">Obligatorio</span></label>
              <input type="text" name="destino_frente" class="form-control" placeholder="CIMENTACION / MUROS NIVEL 2 / ESTRUCTURAS / ACABADOS" required maxlength="120">
              <small class="field-hint">Donde se esta utilizando el material en la obra</small>
            </div>

            <div class="col-12">
              <label class="form-label">Responsable del Retiro <span class="badge badge-required">Obligatorio</span></label>
              <input type="text" name="responsable_movimiento" class="form-control" placeholder="CAPATAZ JUAN / MAESTRO LUIS" required maxlength="120">
              <small class="field-hint">Quien retira/autoriza el despacho del material</small>
            </div>

            <div class="col-12">
              <label class="form-label">Material <span class="badge badge-required">Obligatorio</span></label>
              <input type="text" id="materialSearchInputSalida" class="form-control" placeholder="Escribe para buscar material..." autocomplete="off">
              <div id="materialSuggestionsSalidaDiv" style="position: absolute; background: white; border: 1px solid #d1d5db; border-top: none; border-radius: 0 0 8px 8px; max-height: 200px; overflow-y: auto; width: auto; z-index: 1000; display: none;"></div>
              <select name="almacen_material_id" class="form-select" id="materialSelectSalida" required style="display: none;">
                <option value="">Selecciona material del proyecto</option>
                <% asignaciones.forEach((a) => { %>
                  <option
                    value="<%= a.id %>"
                    data-material-id="<%= a.material_id %>"
                    data-material="<%= up(a.material_nombre) %>"
                    data-unidad="<%= up(a.unidad || '-') %>"
                    data-saldo="<%= Number(a.cantidad_disponible || 0) %>">
                    <%= up(a.material_nombre) %> · <%= up(a.unidad || '-') %> · DISPONIBLE: <%= Number(a.cantidad_disponible || 0).toFixed(2) %>
                  </option>
                <% }) %>
              </select>
              <small class="field-hint">Solo muestra materiales asignados a este proyecto</small>
            </div>

            <div class="col-md-6">
              <label class="form-label">Cantidad de Salida <span class="badge badge-required">Obligatorio</span></label>
              <input type="number" name="cantidad" class="form-control" id="cantidadSalida" placeholder="0" step="0.01" min="0.01" required>
            </div>

            <div class="col-md-6">
              <label class="form-label">Unidad</label>
              <input type="text" class="form-control" id="unidadSalida" readonly placeholder="-">
            </div>

            <div class="col-12">
              <div id="stockValidationMsg" class="stock-validation-msg"></div>
            </div>

            <div class="col-12">
              <label class="form-label">Observacion</label>
              <textarea name="observacion" class="form-control" placeholder="Motivo o detalles de la salida (opcional)" rows="2" maxlength="255"></textarea>
            </div>

            <div class="col-12 pt-1">
              <button class="btn btn-salida" id="btnRegistrarSalida" style="width: 100%; background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); border: none; color: white; padding: 10px 20px; border-radius: 8px; font-weight: 600;">
                <i class="bi bi-check2-circle"></i> Registrar Salida
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-7">
      <div class="panel-card">
        <div class="panel-card-header">
          <div class="panel-title"><i class="bi bi-history"></i> Historial de Salidas</div>
          <span class="badge badge-secondary"><%= salidas.length %> registros</span>
        </div>
        <div class="table-responsive">
          <table class="table align-middle table-hover">
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Frente</th>
                <th>Responsable</th>
                <th>Material</th>
                <th>Cantidad</th>
                <th>Nuevo Saldo</th>
                <th>Observacion</th>
              </tr>
            </thead>
            <tbody>
              <% salidas.forEach((s) => { %>
                <tr>
                  <td><small class="text-muted"><%= fmtFecha(s.fecha) %></small></td>
                  <td>
                    <span class="badge badge-partida"><%= up(s.destino_frente || '-') %></span>
                  </td>
                  <td>
                    <strong class="text-danger"><%= up(s.responsable_movimiento || '-') %></strong>
                  </td>
                  <td>
                    <div class="fw-semibold"><%= up(s.material || '-') %></div>
                    <small class="text-muted"><%= up(s.unidad || '-') %></small>
                  </td>
                  <td class="fw-semibold" style="color: #b91c1c;">
                    <i class="bi bi-arrow-up"></i> <%= Number(s.cantidad || 0).toFixed(2) %>
                  </td>
                  <td class="fw-semibold">
                    <%= Number(s.saldo_resultante || 0).toFixed(2) %> <%= up(s.unidad || '') %>
                  </td>
                  <td><small class="text-muted"><%= up(s.observacion || '-') %></small></td>
                </tr>
              <% }) %>
              <% if (!salidas.length) { %>
                <tr>
                  <td colspan="7">
                    <div class="empty-state">
                      <i class="bi bi-inbox"></i>
                      <p>Sin salidas registradas aun</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .page-header-back {
    display: flex;
    gap: 8px;
  }

  .badge-required {
    background: #fecaca;
    color: #991b1b;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    margin-left: 6px;
  }

  .badge-partida {
    background: #fee2e2;
    color: #7f1d1d;
    border: 1px solid #fca5a5;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
  }

  .stock-validation-msg {
    padding: 12px 14px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    text-align: center;
    display: none;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }

  .stock-validation-msg.show {
    display: flex;
  }

  .stock-validation-msg.warning {
    background: #fef3c7;
    border: 1px solid #fcd34d;
    color: #92400e;
  }

  .stock-validation-msg.error {
    background: #fee2e2;
    border: 1px solid #fca5a5;
    color: #7f1d1d;
  }

  .stock-validation-msg.success {
    background: #dcfce7;
    border: 1px solid #bbf7d0;
    color: #166534;
  }

  .btn-salida {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    border: 1px solid #b91c1c;
    color: white;
    padding: 12px 20px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
    cursor: pointer;
    width: 100%;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .btn-salida:hover:not(:disabled) {
    background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    transform: translateY(-2px);
    color: white;
    text-decoration: none;
  }

  .btn-salida:disabled {
    background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%);
    border-color: #6b7280;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .btn-salida.btn-danger {
    background: linear-gradient(135deg, #f87171 0%, #ef4444 100%);
  }

  .btn-salida i {
    font-size: 18px;
  }

  .form-section {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
  }

  .form-section-title {
    padding: 16px 20px;
    background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%);
    border-bottom: 1px solid #e5e7eb;
    font-size: 16px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
    color: #111827;
  }

  .form-section-title i {
    font-size: 18px;
    color: #ef4444;
  }

  .form-section-body {
    padding: 20px;
  }

  .form-label {
    font-weight: 600;
    color: #111827;
    margin-bottom: 8px;
    display: block;
  }

  .form-control,
  .form-select {
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 14px;
  }

  .form-control:focus,
  .form-select:focus {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  .field-hint {
    display: block;
    margin-top: 4px;
    color: #6b7280;
    font-size: 13px;
  }

  .panel-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
  }

  .panel-card-header {
    padding: 16px 20px;
    background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%);
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .panel-title {
    font-size: 16px;
    font-weight: 600;
    color: #111827;
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
  }

  .panel-title i {
    font-size: 18px;
    color: #ef4444;
  }

  .badge-secondary {
    background: #f3f4f6;
    color: #374151;
    border: 1px solid #e5e7eb;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
  }

  .table-responsive {
    overflow-x: auto;
  }

  .table {
    margin: 0;
    font-size: 13px;
  }

  .table thead {
    background: #f9fafb;
    border-bottom: 2px solid #e5e7eb;
  }

  .table th {
    font-weight: 600;
    color: #374151;
    text-transform: uppercase;
    font-size: 12px;
  }

  .table tbody tr:hover {
