<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Cismining ERP</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <!-- Mobile overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <div class="app-shell">
    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar" id="sidebar">
      <div class="brand">
        <div class="brand-icon"><i class="bi bi-buildings"></i></div>
        <div class="brand-text">
          <h5>Cismining</h5>
          <small>ERP Construcción</small>
        </div>
      </div>

      <div class="sidebar-scroll">
        <div class="menu-section-label">Principal</div>
        <nav class="menu">
          <a class="<%= currentModule === 'dashboard' ? 'active' : '' %>" href="/" title="Dashboard">
            <i class="bi bi-grid-1x2"></i><span>Dashboard</span>
          </a>
          <a class="<%= currentModule === 'obras' ? 'active' : '' %>" href="/obras" title="Obras y Proyectos">
            <i class="bi bi-building"></i><span>Obras y Proyectos</span>
          </a>
          <a class="<%= currentModule === 'gantt' ? 'active' : '' %>" href="/gantt" title="Planeamiento Gantt">
            <i class="bi bi-calendar-range"></i><span>Planeamiento Gantt</span>
          </a>
          <a class="<%= currentModule === 'actividades' ? 'active' : '' %>" href="/actividades" title="Actividades">
            <i class="bi bi-list-check"></i><span>Actividades</span>
          </a>
          <a class="<%= currentModule === 'ingenieria' ? 'active' : '' %>" href="/ingenieria" title="Ingeniería">
            <i class="bi bi-calculator"></i><span>Ingeniería</span>
          </a>
          <a class="<%= currentModule === 'documentos' ? 'active' : '' %>" href="/documentos" title="Documentos">
            <i class="bi bi-folder2-open"></i><span>Documentos</span>
          </a>
        </nav>

        <% if (currentUser && currentUser.role === 'admin') { %>
        <div class="menu-section-label">Administración</div>
        <nav class="menu">
          <a class="<%= currentModule === 'almacen' ? 'active' : '' %>" href="/almacen" title="Almacén">
            <i class="bi bi-box-seam"></i><span>Almacén</span>
          </a>
          <a class="<%= currentModule === 'rrhh' ? 'active' : '' %>" href="/rrhh" title="Recursos Humanos">
            <i class="bi bi-people"></i><span>Recursos Humanos</span>
          </a>
          <a class="<%= currentModule === 'asistencias' ? 'active' : '' %>" href="/asistencias" title="Asistencias">
            <i class="bi bi-calendar2-check"></i><span>Asistencias</span>
          </a>
          <a class="<%= currentModule === 'contabilidad' ? 'active' : '' %>" href="/contabilidad" title="Contabilidad">
            <i class="bi bi-cash-stack"></i><span>Contabilidad</span>
          </a>
          <a class="<%= currentModule === 'caja-chica' ? 'active' : '' %>" href="/caja-chica" title="Caja Chica">
            <i class="bi bi-cash-coin"></i><span>Caja Chica</span>
          </a>
          <a class="<%= currentModule === 'reportes' ? 'active' : '' %>" href="/reportes" title="Reportes">
            <i class="bi bi-bar-chart-line"></i><span>Reportes</span>
          </a>
        </nav>
        <% } %>
      </div>

      <div class="sidebar-footer">
        <i class="bi bi-shield-check"></i>
        <span>v1.0 · Modo seguro</span>
      </div>
    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="main-content">
      <!-- TOPBAR -->
      <header class="topbar">
        <div class="topbar-left">
          <button class="sidebar-toggle" id="sidebarToggle" title="Colapsar menú">
            <i class="bi bi-layout-sidebar"></i>
          </button>
          
        </div>
        <div class="top-actions">
          <% if (currentUser) { %>
            <div class="user-chip-wrapper" id="userChipWrapper">
              <div class="user-chip" id="userChip">
                <span class="avatar"><%= (currentUser.nombre || 'U').slice(0,2).toUpperCase() %></span>
                <div class="user-info">
                  <div class="user-name"><%= currentUser.nombre %></div>
                  <div class="user-role"><%= currentUser.role %></div>
                </div>
                <i class="bi bi-chevron-down chevron"></i>
              </div>
              <div class="user-dropdown">
                <div class="user-dropdown-header">
                  <span class="ud-name"><%= currentUser.nombre %></span>
                  <span class="ud-role"><i class="bi bi-shield-check me-1"></i><%= currentUser.role %></span>
                </div>
                <div class="user-dropdown-menu">
                  <a href="/perfil">
                    <i class="bi bi-person-circle"></i> Mi Perfil
                  </a>
                  <div class="user-dropdown-divider"></div>
                  <form action="/logout" method="post" class="m-0">
                    <button type="submit">
                      <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      </header>

      <!-- PAGE BODY -->
      <section class="page-body">
        <%- body %>
      </section>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/charts.js"></script>
  <script>
    // ── Sidebar toggle ──────────────────────────────────────
    const toggle   = document.getElementById('sidebarToggle');
    const sidebar  = document.getElementById('sidebar');
    const overlay  = document.getElementById('sidebarOverlay');
    const isMobile = () => window.innerWidth <= 992;

    function applyCollapsed(collapsed) {
      if (isMobile()) return;
      document.body.classList.toggle('sidebar-collapsed', collapsed);
      localStorage.setItem('sidebarCollapsed', collapsed ? '1' : '0');
    }

    // Restore state on load
    if (!isMobile() && localStorage.getItem('sidebarCollapsed') === '1') {
      document.body.classList.add('sidebar-collapsed');
    }

    toggle.addEventListener('click', () => {
      if (isMobile()) {
        sidebar.classList.toggle('mobile-open');
        overlay.classList.toggle('active');
      } else {
        applyCollapsed(!document.body.classList.contains('sidebar-collapsed'));
      }
    });

    overlay.addEventListener('click', () => {
      sidebar.classList.remove('mobile-open');
      overlay.classList.remove('active');
    });

    // Add tooltips for collapsed icon-only state
    document.querySelectorAll('.menu a').forEach(link => {
      const label = link.querySelector('span')?.textContent?.trim();
      if (label) link.setAttribute('data-bs-toggle', 'tooltip');
      link.setAttribute('data-bs-placement', 'right');
      link.setAttribute('data-bs-title', label || '');
    });

    // Init Bootstrap tooltips (only show when sidebar is collapsed)
    const tooltips = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltips.forEach(el => {
      const t = new bootstrap.Tooltip(el, { trigger: 'hover' });
      el.addEventListener('show.bs.tooltip', () => {
        if (!document.body.classList.contains('sidebar-collapsed')) t.hide();
      });
    });
    // ── User chip dropdown ──────────────────────────────────
    const userChip    = document.getElementById('userChip');
    const userWrapper = document.getElementById('userChipWrapper');
    if (userChip && userWrapper) {
      userChip.addEventListener('click', (e) => {
        e.stopPropagation();
        userWrapper.classList.toggle('open');
      });
      document.addEventListener('click', () => {
        userWrapper.classList.remove('open');
      });
    }
  </script>
</body>
</html>
